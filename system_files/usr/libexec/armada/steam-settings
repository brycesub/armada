#!/usr/bin/env python3
import json
import sys
import urllib.request

import websocket

CEF_JSON_URL = "http://127.0.0.1:8080/json/list"
GLOBAL_RESOLUTION_KEY = "gamescope_game_resolution_global"


def shared_context_url():
    with urllib.request.urlopen(CEF_JSON_URL, timeout=2) as response:
        pages = json.load(response)
    for page in pages:
        if page.get("title") == "SharedJSContext":
            return page["webSocketDebuggerUrl"]
    raise RuntimeError("Steam SharedJSContext is unavailable")


def eval_shared(expression):
    sock = websocket.create_connection(shared_context_url(), timeout=3)
    try:
        sock.send(json.dumps({
            "id": 1,
            "method": "Runtime.evaluate",
            "params": {
                "expression": expression,
                "returnByValue": True,
                "awaitPromise": True,
            },
        }, separators=(",", ":")))
        while True:
            message = json.loads(sock.recv())
            if message.get("id") != 1:
                continue
            result = message.get("result", {}).get("result", {})
            if result.get("subtype") == "error":
                raise RuntimeError(result.get("description", "Steam CEF evaluation failed"))
            return result.get("value")
    finally:
        sock.close()


def get_setting(key, default=None):
    return eval_shared(f"settingsStore?.GetClientSetting?.({json.dumps(key)})?.[0] ?? {json.dumps(default)}")


def set_setting(key, value):
    expression = (
        f"Promise.resolve(settingsStore.GetClientSetting({json.dumps(key)})[1]({json.dumps(value)}))"
        f".then(() => settingsStore.GetClientSetting({json.dumps(key)})[0])"
    )
    return eval_shared(expression)


def main():
    args = sys.argv[1:]
    command = args[0] if args else ""
    if command == "get-global-resolution":
        print(get_setting(GLOBAL_RESOLUTION_KEY, "Default") or "Default")
    elif command == "set-global-resolution" and len(args) == 2:
        print(set_setting(GLOBAL_RESOLUTION_KEY, args[1]) or "Default")
    else:
        raise SystemExit("usage: steam-settings get-global-resolution|set-global-resolution VALUE")


if __name__ == "__main__":
    main()
